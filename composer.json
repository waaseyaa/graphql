{
    "name": "waaseyaa/graphql",
    "description": "GraphQL endpoint + schema introspection for Waaseyaa — optional/experimental L6 surface; see README for the primary JSON:API framing.",
    "type": "library",
    "license": "GPL-2.0-or-later",
    "repositories": [
        {
            "type": "path",
            "url": "../entity"
        },
        {
            "type": "path",
            "url": "../field"
        },
        {
            "type": "path",
            "url": "../access"
        },
        {
            "type": "path",
            "url": "../foundation"
        },
        {
            "type": "path",
            "url": "../routing"
        },
        {
            "type": "path",
            "url": "../api"
        },
        {
            "type": "path",
            "url": "../workflows"
        }
    ],
    "require": {
        "php": ">=8.5",
        "webonyx/graphql-php": "^15.31.5",
        "waaseyaa/entity": "^0.1.0-alpha.263",
        "waaseyaa/field": "^0.1.0-alpha.263",
        "waaseyaa/access": "^0.1.0-alpha.263",
        "waaseyaa/foundation": "^0.1.0-alpha.263",
        "waaseyaa/routing": "^0.1.0-alpha.263",
        "waaseyaa/api": "^0.1.0-alpha.263",
        "waaseyaa/workflows": "^0.1.0-alpha.263"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "Waaseyaa\\GraphQL\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Waaseyaa\\GraphQL\\Tests\\": "tests/",
            "Waaseyaa\\GraphQL\\Testing\\": "testing/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "extra": {
        "waaseyaa": {
            "providers": [
                "Waaseyaa\\GraphQL\\GraphQlServiceProvider"
            ]
        },
        "branch-alias": {
            "dev-main": "0.1.x-dev",
            "dev-develop/v1.1": "0.1.x-dev"
        }
    },
    "config": {
        "sort-packages": true
    }
}
