{
    "name": "waaseyaa/graphql",
    "description": "GraphQL query and mutation layer for Waaseyaa",
    "type": "library",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.3",
        "waaseyaa/entity": "^0.1",
        "waaseyaa/field": "^0.1",
        "waaseyaa/access": "^0.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "Waaseyaa\\GraphQL\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Waaseyaa\\GraphQL\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "extra": {
        "branch-alias": {
            "dev-develop/v1.1": "0.1.x-dev"
        }
    }
}
